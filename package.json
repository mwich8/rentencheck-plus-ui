  "description": "RentenCheck+ — German Pension Gap Calculator",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test:ci": "ng cache clean && ng test --no-watch --browsers=ChromeHeadless --code-coverage",
    "test:coverage": "ng test --no-watch --browsers=ChromeHeadless --code-coverage",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "ci": "npm run lint && npm run test:ci && npm run build"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.2",
