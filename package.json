    "@types/jasmine": "~5.1.0",
    "angular-eslint": "21.3.0",
    "eslint": "^10.0.2",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.56.1"
  }
