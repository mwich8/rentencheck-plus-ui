    "@angular/platform-browser": "^21.1.2",
    "@angular/platform-browser-dynamic": "^21.1.2",
    "@angular/router": "^21.1.2",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/stripe-js": "^5.10.0",
    "echarts": "^5.6.0",
    "jspdf": "^4.2.0",
    "ngx-echarts": "^19.0.0",
    "resend": "^6.9.4",
    "rxjs": "~7.8.0",
    "stripe": "^17.7.0",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
